# Copy to .env.local and fill in as needed. All vars are optional for local dev.
#
# Optional: set for release builds (default 0.1.0)
# NEXT_PUBLIC_APP_VERSION=1.0.0

# Optional: base URL for sitemap and OG (default https://herdmanager.example.com)
# NEXT_PUBLIC_BASE_URL=https://your-domain.com

# Firebase (create project at console.firebase.google.com)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional: server-only. JSON string of service account key for /api/stats and /api/devices.
# If unset, Firebase Admin uses GOOGLE_APPLICATION_CREDENTIALS or default credentials.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Optional: use Cloud Functions for stats and devices (Option B). When true and user is signed in,
# the dashboard calls getHerdStats and getDevices callables instead of Firestore or Next.js API.
# Deploy functions first: see functions/README.md.
# NEXT_PUBLIC_USE_STATS_VIA_CALLABLE=true

# Multi-instance: unique solution/instance ID for this deployment (set when provisioning a new farm).
# Used for support and feedback links so requests are tagged with the instance.
# NEXT_PUBLIC_SOLUTION_ID=acme-farm-01

# Optional: base URL for support portal (e.g. https://support.yourproduct.com). If set, Settings shows
# "Help & support", "Suggest a feature", and "Report a problem" links with solutionId in query.
# NEXT_PUBLIC_SUPPORT_URL=https://support.herdmanager.example.com

# Phase Later – billing status (server-only). When billing is integrated, set these so GET /api/v1/billing-status returns plan/status.
# BILLING_PLAN=basic
# BILLING_STATUS=active
# BILLING_CUSTOMER_ID=cus_xxx
