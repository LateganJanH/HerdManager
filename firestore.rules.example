// Example Firestore security rules for HerdManager.
// Copy to Firebase Console → Firestore Database → Rules (or deploy with Firebase CLI).
//
// Data layout: users/{userId}/animals, breeding_events, calving_events, devices, transactions, expense_categories, etc.
// Only the signed-in user may read/write their own users/{userId}/... subtree.
// Android writes to users/{uid}/devices/{deviceId} on each sync for the web "linked devices" list.
//
// Optional app config: users/{userId}/config/app with minVersionCode (integer), accessSuspended (boolean), and/or blockSyncAfterEpochMs (number).
// minVersionCode: Android shows "Update required" when BuildConfig.VERSION_CODE < minVersionCode.
// accessSuspended: when true, Android shows "Subscription lapsed. Contact support." (billing; see docs/BILLING-IMPLEMENTATION.md §3.4).
// blockSyncAfterEpochMs: optional EOL; when set and current time >= value, Android blocks sync and shows "Update required" (see RELEASE-CHECKLIST § Deprecation and EOL).
// Write this doc from the web dashboard, a script, or billing webhook; the app only reads it.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Global app config (e.g. accessSuspended from billing webhook). Server writes; clients read.
    match /config/app {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
